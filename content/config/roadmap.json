        { "day": 4, "dayId": "day04", "title": "Day 04", "mission": "Week 1 curriculum.", "difficulty": "beginner" },
        { "day": 5, "dayId": "day05", "title": "Day 05", "mission": "Week 1 curriculum.", "difficulty": "intermediate" },
